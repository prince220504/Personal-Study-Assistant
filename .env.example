# Copy this file to .env and fill in your real key.
# .env is gitignored — never commit it.

GROQ_API_KEY=gsk_your_key_here

# Optional: HuggingFace token to avoid rate-limit warnings when downloading
# the embedding model. Get one free at https://huggingface.co/settings/tokens
HF_TOKEN=hf_your_token_here
